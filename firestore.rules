rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read all users (for admin functions) but only write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Menu items - authenticated users can read/write
    match /menu/{menuId} {
      allow read, write: if request.auth != null;
    }
    
    // Orders - authenticated users can read/write
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    // Reservations - authenticated users can read/write
    match /reservations/{reservationId} {
      allow read, write: if request.auth != null;
    }
    
    // Custom items - authenticated users can read/write
    match /customItems/{itemId} {
      allow read, write: if request.auth != null;
    }
    
    // Staff - authenticated users can read/write
    match /staff/{staffId} {
      allow read, write: if request.auth != null;
    }
    
    // Tables - authenticated users can read/write
    match /tables/{tableId} {
      allow read, write: if request.auth != null;
    }
  }
}
